<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">


<mapper namespace="com.example.forum.mapper.MediaFileMapper">

    <update id="batchBindToPost">
        UPDATE media_file
        SET
        ref_type = 'post',
        ref_id = #{postId}
        WHERE id IN
        <foreach collection="ids"
                 item="id"
                 open="("
                 separator=","
                 close=")">
            #{id}
        </foreach>
    </update>

    <update id="unbindByPost">
        UPDATE media_file
        SET ref_type = NULL,
            ref_id = NULL
        WHERE ref_type = 'post'
          AND ref_id = #{postId}
    </update>




</mapper>