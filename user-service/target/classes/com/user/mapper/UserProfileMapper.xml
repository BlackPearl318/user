<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">


<mapper namespace="com.user.mapper.UserProfileMapper">

    <insert id="insertUserProfile">
        INSERT INTO user_profiles
            (user_id,name,gender,date_of_birth,biography,avatar)
            VALUE
            (#{userId},#{name},'保密','0000-00-00','','')
    </insert>

    <select id="selectUserProfileById" resultType="com.user.pojo.UserProfile">
        SELECT
            name,
            gender,
            date_of_birth,
            biography,
            avatar
        FROM user_profiles
        WHERE user_id = #{userId}
    </select>
    <select id="selectUserName" resultType="java.lang.String">
        SELECT name
        FROM user_profiles
        WHERE user_id = #{userId}
    </select>
    <select id="selectUserAvatar" resultType="java.lang.String">
        SELECT avatar
        FROM user_profiles
        WHERE user_id = #{userId}
    </select>

    <update id="updateUserProfile" parameterType="com.user.pojo.UserProfile">
        UPDATE user_profiles
        <set>
            <if test="userProfile.name != null and userProfile.name != ''">
                name = #{userProfile.name},
            </if>
            <if test="userProfile.gender != null and userProfile.gender != ''">
                gender = #{userProfile.gender},
            </if>
            <if test="userProfile.dateOfBirth != null">
                date_of_birth = #{userProfile.dateOfBirth},
            </if>
            <if test="userProfile.biography != null and userProfile.biography != ''">
                biography = #{userProfile.biography},
            </if>
            user_id = user_id
        </set>
        WHERE user_id = #{userProfile.userId}
    </update>
    <update id="updateUserAvatarProfile">
        UPDATE user_profiles
        <set>
            avatar = #{avatar}
        </set>
        WHERE user_id = #{userId}
    </update>


</mapper>